# This app does not load .env itself; it only reads os.getenv().
# On the droplet, globapp-api.service uses EnvironmentFile=/etc/globapp-api.env.
# For migrations, run: sudo bash -c 'set -a; source /etc/globapp-api.env; set +a; psql "$DATABASE_URL" -f migrations/007_add_ride_messages.sql'
#
# Default from database.py (used when DATABASE_URL is unset):
#   postgresql://globapp_user:2024@127.0.0.1:5432/globapp_db
# If env is not set, you can run: psql "postgresql://globapp_user:2024@127.0.0.1:5432/globapp_db" -f migrations/007_add_ride_messages.sql

# Required: PostgreSQL connection string (override default from database.py)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# API keys (backend validates these)
GLOBAPP_PUBLIC_API_KEY=your_public_api_key
GLOBAPP_ADMIN_API_KEY=your_admin_api_key

# Required for driver login (JWT)
GLOBAPP_JWT_SECRET=your_jwt_secret_at_least_32_chars

# Optional
GLOBAPP_ACCESS_TOKEN_MINUTES=15
GLOBAPP_REFRESH_TOKEN_DAYS=30
APP_ENV=production

# Optional: Stripe (if using Stripe payments)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: Google Maps (if used)
# GOOGLE_MAPS_API_KEY=...
